NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vigilancia_habitacao?schema=public
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
CADU_ATUALIZACAO_MESES=24
REDIS_URL=redis://localhost:6379

# Assistente RAG (https://saas-agentes-sistema-rag.90qhxz.easypanel.host/api-docs)
RAG_API_BASE_URL=https://saas-agentes-sistema-rag.90qhxz.easypanel.host
RAG_API_KEY=
RAG_KNOWLEDGE_BASE_ID=4

# Modelo de linguagem (orquestrador: contexto + RAG como apoio + mensagem)
OPENAI_API_KEY=
# ID completo do modelo na OpenAI (Chat Completions). Exemplos: gpt-4o-mini, gpt-4o, gpt-4.1
# NAO use apenas "4.1" — isso vira nome invalido. Lista: https://platform.openai.com/docs/models
OPENAI_MODEL=gpt-4o-mini
