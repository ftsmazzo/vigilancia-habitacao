NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vigilancia_habitacao?schema=public
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
CADU_ATUALIZACAO_MESES=24
REDIS_URL=redis://localhost:6379

# Assistente RAG (https://saas-agentes-sistema-rag.90qhxz.easypanel.host/api-docs)
RAG_API_BASE_URL=https://saas-agentes-sistema-rag.90qhxz.easypanel.host
RAG_API_KEY=
RAG_KNOWLEDGE_BASE_ID=4

# Modelo de linguagem (orquestrador: contexto + RAG como apoio + mensagem)
OPENAI_API_KEY=
# ID completo do modelo na OpenAI (Chat Completions). Exemplos: gpt-4o-mini, gpt-4o, gpt-4.1
# NAO use apenas "4.1" — isso vira nome invalido. Lista: https://platform.openai.com/docs/models
OPENAI_MODEL=gpt-4o-mini

# Perfil municipal do assistente e do proxy /assistente/agente-n8n (contexto injetado no payload).
# Codigo IBGE de 7 digitos. Com varios cadastros no banco, escolhe este.
# Sem variavel: usa o perfil mais recentemente atualizado.
MUNICIPIO_IBGE_CODIGO=

# Laboratorio: Agente Vigilancia no n8n (POST teste a partir do painel)
# URL completa do no Webhook no n8n (ex.: https://n8n.../webhook/ce26fa30-...)
N8N_AGENTE_VIGILANCIA_WEBHOOK_URL=
# Opcional: enviado como Authorization: Bearer <valor>
N8N_AGENTE_VIGILANCIA_WEBHOOK_SECRET=
# Timeout em ms para o proxy (padrao 120000)
# N8N_AGENTE_VIGILANCIA_TIMEOUT_MS=120000
