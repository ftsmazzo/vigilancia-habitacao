generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id         String    @id @default(uuid())
  nome       String
  email      String    @unique
  senhaHash  String
  role       Role      @default(HABITACAO)
  ativo      Boolean   @default(true)
  criadoEm   DateTime  @default(now())
  atualizadoEm DateTime @updatedAt
}

enum Role {
  MASTER
  ADMIN
  HABITACAO
  VIGILANCIA
}

model Empreendimento {
  id               String           @id @default(uuid())
  nome             String
  endereco         String?
  municipio        String?
  numUnidades      Int?
  status           StatusEmp        @default(EM_CAPTACAO)
  criadoPorUsuarioId String?
  criadoEm         DateTime         @default(now())
  atualizadoEm     DateTime         @updatedAt
  preSelecionados  PreSelecionado[]
}

enum StatusEmp {
  EM_CAPTACAO
  EM_ANALISE
  CONCLUIDO
}

model CaduPessoa {
  id                 String   @id @default(uuid())
  cpf                String   @unique
  nomePessoa         String?
  nisPessoa          String?
  dataNascimento     DateTime?
  sexo               String?
  codFamiliarFam     String?
  dataAtualFam       DateTime?
  recebePbfFam       Boolean?
  recebePbfPessoa    Boolean?
  rendaPerCapitaFam  Decimal?
  composicaoFamiliar Int?
  moradiaJson        Json?
  origemRefCad       String?
  importadoEm        DateTime @default(now())
  atualizadoEm       DateTime @updatedAt
}

model CaduFamilia {
  id                 String   @id @default(uuid())
  codFamiliarFam     String   @unique
  dataAtualFam       DateTime?
  rendaPerCapitaFam  Decimal?
  composicaoFamiliar Int?
  recebePbfFam       Boolean?
  municipio          String?
  endereco           String?
  rawDadosTxt        String?
  importadoEm        DateTime @default(now())
  atualizadoEm       DateTime @updatedAt
}

model CaduRawImport {
  id           String   @id @default(uuid())
  nomeArquivo  String
  status       String
  totalLinhas  Int      @default(0)
  criadoPorId  String?
  criadoEm     DateTime @default(now())
  finalizadoEm DateTime?
}

model CaduRawLinha {
  id             String   @id @default(uuid())
  importId       String
  linhaNumero    Int
  codFamiliarFam String?
  cpfPessoa      String?
  dadosTxt       String
  criadoEm       DateTime @default(now())

  @@index([importId])
  @@index([codFamiliarFam])
  @@index([cpfPessoa])
}

model BpcBeneficio {
  id                   String   @id @default(uuid())
  cpf                  String   @unique
  nomeTitular          String?
  numeroBeneficio      String?
  especieBeneficio     String?
  tipo                 BpcTipo  @default(OUTRO)
  situacao             String?
  cadunico             String?
  situacaoCadastral    String?
  dataAtualizacaoFam   DateTime?
  competenciaPeriodo   DateTime?
  municipio            String?
  uf                   String?
  importadoEm          DateTime @default(now())
  atualizadoEm         DateTime @updatedAt
}

enum BpcTipo {
  IDOSO
  DEFICIENTE
  OUTRO
}

model PreSelecionado {
  id                        String         @id @default(uuid())
  empreendimentoId          String
  empreendimento            Empreendimento @relation(fields: [empreendimentoId], references: [id], onDelete: Cascade)
  cpf                       String
  nomeInformado             String?
  nisInformado              String?
  dataAtualizacaoInscricao  DateTime?
  contato                   String?
  observacoes               String?
  camposOriginaisPlanilha   Json?
  statusCruzamento          StatusCruz     @default(PENDENTE)
  statusVigilancia          StatusVigilancia @default(PENDENTE_ANALISE)
  motivoStatus              String?
  recebePbf                Boolean?
  cruzadoEm                 DateTime?
  dadosCruzados             DadosCruzados?
  criadoEm                  DateTime       @default(now())
  atualizadoEm              DateTime       @updatedAt

  @@unique([empreendimentoId, cpf])
}

enum StatusCruz {
  PENDENTE
  ENCONTRADO
  NAO_ENCONTRADO
}

enum StatusVigilancia {
  PENDENTE_ANALISE
  NAO_ENCONTRADO
  DESATUALIZADO
  ATUALIZADO
}

model DadosCruzados {
  id               String         @id @default(uuid())
  preSelecionadoId String         @unique
  preSelecionado   PreSelecionado @relation(fields: [preSelecionadoId], references: [id], onDelete: Cascade)
  camposCADU       Json
  camposAdicionais Json?
  atualizadoEm     DateTime       @updatedAt
}

model LogAuditoria {
  id        String   @id @default(uuid())
  usuarioId String?
  acao      String
  detalhes  Json?
  criadoEm  DateTime @default(now())
}

/// Definicoes de indicadores RMA (rotulos para painel e tooltips)
model RmaIndicadorDef {
  codigo String @id
  rotulo String
  grupo  String?
  ordem  Int    @default(0)
}

/// Nomes padrao para exibicao (ASCII) por id_cras — evita caracteres corrompidos do CSV oficial
model RmaCrasUnidadeDef {
  idCras       String @id
  rotuloPadrao String
  ordem        Int    @default(0)
}

/// Registro mensal RMA por CRAS (chave natural: mes referencia + id_cras)
model RmaRegistroMensal {
  id            String   @id @default(uuid())
  mesReferencia DateTime
  idCras        String
  nomeUnidade   String?
  endereco      String?
  municipio     String?
  uf            String?

  a1  Int?
  a2  Int?
  b1  Int?
  b2  Int?
  b3  Int?
  b4  Int?
  b5  Int?
  b6  Int?
  c1  Int?
  c2  Int?
  c3  Int?
  c4  Int?
  c5  Int?
  c6  Int?
  c7  Int?
  c8  Int?
  c9  Int?
  d1  Int?
  d2  Int?
  d3  Int?
  d4  Int?
  d5  Int?
  d6  Int?
  d7  Int?
  d8  Int?

  coordenadorCras String?
  cpfCoordenador  String?
  codigoIbge      String?

  importadoEm  DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@unique([mesReferencia, idCras])
  @@index([mesReferencia])
  @@index([idCras])
}

/// Definicoes de indicadores RMA CREAS (rotulos)
model RmaCreasIndicadorDef {
  codigo String @id
  rotulo String
  grupo  String?
  ordem  Int    @default(0)
}

/// Registro mensal RMA por CREAS (chave: mes referencia + id_creas; metricas dinamicas em JSON)
model RmaCreasRegistroMensal {
  id               String   @id @default(uuid())
  mesReferencia    DateTime
  idCreas          String
  nomeUnidade      String?
  endereco         String?
  municipio        String?
  uf               String?
  coordenadorCreas String?
  cpfCoordenador   String?
  codigoIbge       String?
  metricas         Json

  importadoEm  DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@unique([mesReferencia, idCreas])
  @@index([mesReferencia])
  @@index([idCreas])
}

/// Definicoes de indicadores RMA Centro POP
model RmaPopIndicadorDef {
  codigo String @id
  rotulo String
  grupo  String?
  ordem  Int    @default(0)
}

/// Registro mensal RMA Centro POP (mes referencia + id unidade; metricas JSON)
model RmaPopRegistroMensal {
  id               String   @id @default(uuid())
  mesReferencia    DateTime
  idUnidade        String
  nomeUnidade      String?
  endereco         String?
  municipio        String?
  uf               String?
  coordenadorPop   String?
  cpfCoordenador   String?
  codigoIbge       String?
  metricas         Json

  importadoEm  DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@unique([mesReferencia, idUnidade])
  @@index([mesReferencia])
  @@index([idUnidade])
}

/// Perfil territorial e institucional do municipio atendido pelo sistema (contexto fixo para o assistente).
/// Replicar em outro municipio: novo registro + variavel MUNICIPIO_IBGE_CODIGO apontando para o codigoIbge.
model MunicipioPerfil {
  id              String    @id @default(uuid())
  codigoIbge      String    @unique @db.VarChar(7)
  nome            String
  uf              String    @db.VarChar(2)
  /// Campos flexiveis: qtdCras, qtdCreas, qtdCentroPop, populacao, redeServicos, cadunicoResumo, etc.
  dadosJson       Json      @default("{}")
  /// Narrativa livre para o LLM (territorio, pactuacoes, observacoes locais)
  textoMunicipio  String?   @db.Text
  /// Cache da API de localidades municipais IBGE
  ibgeCacheJson   Json?
  ibgeCacheEm     DateTime?
  criadoEm        DateTime  @default(now())
  atualizadoEm    DateTime  @updatedAt
}

/// Historico de chat do Postgres Chat Memory do n8n (LangChain). Tabela criada e preenchida pelo n8n.
/// @@ignore: Prisma nao gerencia migrate/db push nesta tabela — evita drop acidental no mesmo banco do app.
model N8nChatHistories {
  id         Int    @id @default(autoincrement())
  session_id String @db.VarChar(255)
  message    Json   @db.JsonB

  @@map("n8n_chat_histories")
  @@ignore
}
